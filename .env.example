# Environment variables for europe-map-1230
# Copy to .env (gitignored) and adjust as needed.
# Vite reads only variables prefixed with VITE_.

# Public base path under which the app is served.
# Production: https://timgrid.github.io/europe-map-1230/  →  /europe-map-1230/
# Local dev:   http://localhost:5173/europe-map-1230/    →  /europe-map-1230/
# Override only if deploying to a different subpath.
VITE_BASE_URL=/europe-map-1230/
